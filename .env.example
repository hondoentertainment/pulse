# ── Supabase ─────────────────────────────────────────────────
# Required: obtain from your Supabase project dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Service-role key – only needed server-side (migrations, Edge Functions).
# NEVER expose this in client-side code.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Direct database connection – used by `supabase db push` and migration tooling.
# SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres

# ── Feature flags ────────────────────────────────────────────
VITE_FF_ENABLE_INTEGRATIONS=true
VITE_FF_ENABLE_SOCIAL_DASHBOARD=true
VITE_FF_ENABLE_SMART_MAP=true

# ── Mapbox ───────────────────────────────────────────────────
# Optional: Mapbox GL access token for real map tiles.
# Get one at https://account.mapbox.com/access-tokens/
# When empty the app falls back to the canvas-only dark-gradient background.
VITE_MAPBOX_TOKEN=

# ── Testing ──────────────────────────────────────────────────
# Optional override for Playwright smoke tests in CI/local.
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:4173
