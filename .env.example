# ── Supabase ─────────────────────────────────────────────────
# Required: obtain from your Supabase project dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Service-role key – only needed server-side (migrations, Edge Functions).
# NEVER expose this in client-side code.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Direct database connection – used by `supabase db push` and migration tooling.
# SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres

# ── Feature flags ────────────────────────────────────────────
VITE_FF_ENABLE_INTEGRATIONS=true
VITE_FF_ENABLE_SOCIAL_DASHBOARD=true
VITE_FF_ENABLE_SMART_MAP=true

# ── Mapbox ───────────────────────────────────────────────────
# Optional: Mapbox GL access token for real map tiles.
# Get one at https://account.mapbox.com/access-tokens/
# When empty the app falls back to the canvas-only dark-gradient background.
VITE_MAPBOX_TOKEN=

# ── Testing ──────────────────────────────────────────────────
# Optional override for Playwright smoke tests in CI/local.
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:4173

# ── Server-side integration secrets ──────────────────────────
# These power the Edge Functions in api/integrations/, api/webhooks/,
# and api/keys/. They are SERVER-ONLY — do NOT prefix with VITE_ or
# they will be inlined into the client bundle.
# See docs/secrets-and-integrations.md for rotation procedure.

# Supabase server-side overrides (fall back to VITE_SUPABASE_* if unset).
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# Comma-separated allowlist of admin emails for /api/keys/generate.
# SUPABASE_ADMIN_EMAILS=ops@example.com,admin@example.com

# Spotify Web API — client_credentials flow for catalog reads,
# user OAuth tokens passed via X-Spotify-Token header for playlists.
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=

# Uber server token — get from https://developer.uber.com/dashboard
# UBER_SERVER_TOKEN=

# Lyft OAuth client credentials — https://www.lyft.com/developers
# LYFT_CLIENT_ID=
# LYFT_CLIENT_SECRET=

# Mapbox server token (separate from VITE_MAPBOX_TOKEN — the server
# token must NOT have URL restrictions so it works from Vercel IPs).
# MAPBOX_SERVER_TOKEN=

# Google Maps server key (only needed if calling /api/integrations/geocode?provider=google).
# GOOGLE_MAPS_SERVER_KEY=

# HMAC-SHA256 secret used by /api/webhooks/sign. Per-subscription
# overrides are also supported via WEBHOOK_HMAC_SECRET_<UPPER_ID>.
# WEBHOOK_HMAC_SECRET=
