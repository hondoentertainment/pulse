# ── Supabase (optional — without these, app uses mock data) ──
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# VITE_USE_SUPABASE_BACKEND=false   # force mock even with creds set

# ── App shell (default: signal) ──
# VITE_APP_MODE=signal              # production default — Pulse Signal
# VITE_APP_MODE=venue               # full venue discovery PWA (E2E / staging)

# ── Feature flags (see docs/feature-flags.md) ──
VITE_FF_ENABLE_INTEGRATIONS=true
VITE_FF_ENABLE_SOCIAL_DASHBOARD=true
VITE_FF_ENABLE_SMART_MAP=true
# VITE_TICKETING_ENABLED=0
# VITE_AI_CONCIERGE_ENABLED=0
# VITE_CREATOR_ECONOMY_ENABLED=0
# VITE_VIDEO_FEED_ENABLED=0
# VITE_SAFETY_KIT_ENABLED=1

# ── Maps & observability (optional) ──
# VITE_MAPBOX_TOKEN=pk.eyJ...
# VITE_SENTRY_DSN=https://...
# VITE_ANALYTICS_BACKEND=console

# ── Misc ──
# VITE_RESEARCH_FEEDBACK_URL=https://   # survey / Calendly in Settings

# ── Testing (CI / Playwright) ──
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:4173
# VITE_E2E_AUTH_BYPASS=true

# Full env reference: docs/getting-started.md, docs/secrets-and-integrations.md
